TZ=Etc/UTC

NPMPLUS_IMAGE=docker.io/zoeyvid/npmplus:latest
NPMPLUS_DATA_DIR=/opt/npmplus
NPM_PORT=81
GOA_PORT=91
HTTP_PORT=80
HTTPS_PORT=443
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me
COOKIE_SECRET=change-me

CROWDSEC_IMAGE=docker.io/crowdsecurity/crowdsec:latest
CROWDSEC_CONFIG_DIR=/opt/crowdsec/conf
CROWDSEC_DATA_DIR=/opt/crowdsec/data
CROWDSEC_APPSEC_PORT=7422
CROWDSEC_LAPI_PORT=8080

ANUBIS_IMAGE=ghcr.io/techarohq/anubis:latest
ANUBIS_PORT=8923
ANUBIS_METRICS_PORT=9090
ANUBIS_LOG_LEVEL=INFO
