# Environment values generated from Portainer template: Immich {shmolf}

# Source: Portainer field
# PUID
PUID=1000

# Source: Portainer field
# PGID
PGID=1000

# Source: Portainer field
# To want to lock to a specific tag, provide a value such as 'v1.71.0'
IMMICH_VERSION=release

# Source: Portainer field
# Database username
DB_USERNAME=postgres

# Source: Portainer field
# This should be changed to a random secret
DB_PASSWORD=change-me

# Source: Portainer field
# Database name
DB_DATABASE_NAME=immich

# Source: Portainer field
# The default value references a service within the stack
DB_HOSTNAME=immich_postgres

# Source: Portainer field
# You can leave this path as-is, and the system will auto-create the needed folders. Feel free to change if you desire an alternative location.
UPLOAD_LOCATION=/portainer/Files/AppData/Immich/upload

# Source: Portainer field
# The default value references a service within the stack
REDIS_HOSTNAME=immich_redis

# Source: Portainer field
# Http Port
PORT=2283
