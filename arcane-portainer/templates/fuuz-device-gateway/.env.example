# Environment values generated from Portainer template: Fuuz Device Gateway

# Source: Portainer field
# When the Fuuz API key is provided, the gateway will connect to the cloud on startup and not require the API Key to be created at first launch.
FUUZ_API_KEY=change-me

# Source: Portainer field
# Enable Auto Update
FUUZ_GATEWAY_AUTO_UPDATE=

# Source: Portainer field
# Log Level
FUUZ_GATEWAY_LOG_LEVEL=

# Source: Portainer field
# Log Retention Days
FUUZ_GATEWAY_LOG_RETENTION_DAYS=30

# Source: Portainer field
# Gateway Port
FUUZ_GATEWAY_PORT=5500

# Source: Portainer field
# Listen Address
FUUZ_GATEWAY_LISTEN_ADDRESS=0.0.0.0

# Source: Compose variable
CONTAINER_NAME=fuuz-device-gateway
