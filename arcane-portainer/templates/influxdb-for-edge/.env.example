# Environment values generated from Portainer template: InfluxDB for Edge

# Source: Portainer field
# Original Portainer variable name: influxadmin
# Influx Admin Username
INFLUXADMIN=

# Source: Portainer field
# Original Portainer variable name: influxadminpass
# Influx Admin User Password
INFLUXADMINPASS=change-me

# Source: Portainer field
# Original Portainer variable name: influxorg
# Influx Org Name
INFLUXORG=

# Source: Portainer field
# Original Portainer variable name: influxbucket
# Influx Bucket Name
INFLUXBUCKET=

# Source: Compose environment
DOCKER_INFLUXDB_INIT_MODE=setup
