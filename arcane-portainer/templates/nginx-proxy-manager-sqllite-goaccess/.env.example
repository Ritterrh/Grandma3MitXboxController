# Environment values generated from Portainer template: Nginx Proxy Manager v2 with Sqlite and Goaccess Charts

# Source: Portainer field
# PUID
PUID=1000

# Source: Portainer field
# PGID
PGID=1000

# Source: Portainer field
# TZ
TZ=America/New_York

# Source: Portainer field
# Defaults to false. Set to true to skip archived logs, i.e. proxy-host*.gz
SKIP_ARCHIVED_LOGS=false

# Source: Portainer field
# Defaults to false. Set to true to enable nginx basic authentication. Docker container needs to stopped or restarted each time this flag is modified. This allows for the .htpasswd file to be changed accordingly.
BASIC_AUTH=false

# Source: Portainer field
# (Optional) Requires BASIC_AUTH to bet set to true. Username for basic authentication.
BASIC_AUTH_USERNAME=user

# Source: Portainer field
# (Optional) Requires BASIC_AUTH to bet set to true. Password for basic authentication.
BASIC_AUTH_PASSWORD=change-me
