# Environment values generated from Portainer template: Dokku (stack)

# Source: Portainer field
# Version of Dokku to use ('latest' if empty)
VERSION=latest

# Source: Portainer field
# Global hostname to be registered by Dokku
DOKKU_HOSTNAME=localhost

# Source: Portainer field
# Host path to be bound to /mnt/dokku (`/var/lib/dokku` if empty)
VOLUME_PATH=/var/lib/dokku

# Source: Portainer field
# Image build cache path. Generally set to <data dir> + '/home/dokku'
DOKKU_HOST_ROOT=/var/lib/dokku/home/dokku

# Source: Portainer field
# Host port to expose SSH port of Dokku (22 if empty)
SSH_PORT=22

# Source: Portainer field
# Host port to expose HTTP port of Dokku (80 if empty)
HTTP_PORT=80

# Source: Portainer field
# Host port to expose HTTPS port of Dokku (443 if empty)
HTTPS_PORT=443
