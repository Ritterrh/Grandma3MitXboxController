# Environment values generated from Portainer template: Calibre Web

# Source: Portainer field
# for UserID
PUID=15000

# Source: Portainer field
# for GroupID
PGID=15000

# Source: Portainer field
# Specify a timezone to use for example Europe/Amsterdam
TZ=America/Los_Angeles

# Source: Portainer field
# #optional & **x86-64 only** Adds the ability to perform ebook conversion
DOCKER_MODS=linuxserver/mods:universal-calibre

# Source: Portainer field
# Optionally set this to allow Google OAUTH to work
OAUTHLIB_RELAX_TOKEN_SCOPE=change-me

# Source: Compose variable
CONTAINER_NAME=calibreweb
