# Environment values generated from Portainer template: Wordpress (stack)

# Source: Portainer field
# External Port for webserver forward to port 80
WEB_SERVER_PORT=5080

# Source: Portainer field
# Database user name
MYSQL_DATABASE_USER_NAME=wordpress

# Source: Portainer field
# Database password for user
MYSQL_DATABASE_PASSWORD=change-me

# Source: Portainer field
# Database root password
MYSQL_DATABASE_ROOT_PASSWORD=change-me

# Source: Compose environment
WORDPRESS_DB_HOST=db:3306

# Source: Compose environment
WORDPRESS_DB_NAME=wordpress

# Source: Compose environment
MYSQL_DATABASE=wordpress
