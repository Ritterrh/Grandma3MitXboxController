# Environment values generated from Portainer template: Mozilla Syncserver

# Source: Portainer field
# SYNCSERVER_PUBLIC_URL
SYNCSERVER_PUBLIC_URL=https://syncserver.depot.lan

# Source: Portainer field
# SYNCSERVER_SECRET_FILE
SYNCSERVER_SECRET_FILE=change-me

# Source: Portainer field
# SYNCSERVER_SQLURI
SYNCSERVER_SQLURI=sqlite:////data/syncserver.db

# Source: Portainer field
# SYNCSERVER_BATCH_UPLOAD_ENABLED
SYNCSERVER_BATCH_UPLOAD_ENABLED=true

# Source: Portainer field
# SYNCSERVER_FORCE_WSGI_ENVIRON
SYNCSERVER_FORCE_WSGI_ENVIRON=false

# Source: Portainer field
# PORT
PORT=5000

# Source: Compose variable
CONTAINER_NAME=syncserver
