# Environment values generated from Portainer template: Wireguard Server

# Source: Portainer field
# Set here your DDNS domain
WG_HOST=example.domain.com

# Source: Portainer field
# Leave blank to access WebUI without loggin
PASSWORD=change-me

# Source: Portainer field
# WG_PORT
WG_PORT=51820

# Source: Portainer field
# WG_DEFAULT_DNS
WG_DEFAULT_DNS=1.1.1.1

# Source: Portainer field
# WG_DEFAULT_ADDRESS
WG_DEFAULT_ADDRESS=10.8.0.x

# Source: Portainer field
# WG_ALLOWED_IPS
WG_ALLOWED_IPS=0.0.0.0/0, ::/0
