# Environment values generated from Portainer template: Faster-whisper

# Source: Portainer field
# Run 'id [USER]' for the owner of the host volume directories to get the UID to use here.
PUID=1000

# Source: Portainer field
# Run 'id [USER]' for the owner of the host volume directories to get the GID to use here.
PGID=1000

# Source: Portainer field
# specify a timezone to use, see this [list](https://en.wikipedia.org/wiki/List_of_tz_database_time_zones#List).
TZ=Etc/UTC

# Source: Portainer field
# If set to `true`, or any other value, the container will output debug logs. [OPTIONAL]
DEBUG=

# Source: Portainer field
# If set to `true`, or any other value, the container will not attempt to download models from HuggingFace and will only use locally-provided models. [OPTIONAL]
LOCAL_ONLY=

# Source: Portainer field
# Number of candidates to consider simultaneously during transcription. [OPTIONAL]
WHISPER_BEAM=1

# Source: Portainer field
# Two character code for the language that you will speak to the add-on. [OPTIONAL]
WHISPER_LANG=auto

# Source: Portainer field
# Whisper model that will be used for transcription. From [here](https://github.com/SYSTRAN/faster-whisper/blob/master/faster_whisper/utils.py#L11-L31). [OPTIONAL]
WHISPER_MODEL=auto

# Source: Compose variable
CONTAINER_NAME=faster-whisper
