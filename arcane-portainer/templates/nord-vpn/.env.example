# Environment values generated from Portainer template: nord-vpn

# Source: Portainer field
# NordVPN user
USER=user@email.com

# Source: Portainer field
# NordVPN password
PASS=change-me

# Source: Portainer field
# Countries to connect to (see webpage readme)
COUNTRY=Spain;Hong Kong;IE;131

# Source: Portainer field
# Group name filter to which to connect to
GROUP=Standard VPN servers

# Source: Portainer field
# Range of servers to pick from the top
RANDOM_TOP=10

# Source: Portainer field
# Define when to look again for new defined servers
RECREATE_VPN_CRON=5 */3 * * *

# Source: Portainer field
# URL to check internet connection is working to
CHECK_CONNECTION_URL=https://www.google.com

# Source: Portainer field
# Subnet to define network access (read Local Network access to services connecting to the internet through the VPN readme to get the right subnet!)
NETWORK=192.168.1.0/24;192.168.2.0/24

# Source: Portainer field
# Used to pass extra parameters to openvpn
OPENVPN_OPTS=--mute-replay-warnings

# Source: Compose variable
CONTAINER_NAME=nord-vpn
