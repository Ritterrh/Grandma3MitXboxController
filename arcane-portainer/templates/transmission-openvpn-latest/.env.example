# Environment values generated from Portainer template: Transmission OpenVPN Latest

# Source: Portainer field
# PUID
PUID=1000

# Source: Portainer field
# PGID
PGID=1000

# Source: Portainer field
# https://haugene.github.io/docker-transmission-openvpn/supported-providers/
OPENVPN_PROVIDER=MULLVAD

# Source: Portainer field
# Optional. Mostly used to narrow down what location to use by the provider
OPENVPN_CONFIG=

# Source: Portainer field
# OPENVPN_USERNAME
OPENVPN_USERNAME=user

# Source: Portainer field
# OPENVPN_PASSWORD
OPENVPN_PASSWORD=change-me

# Source: Portainer field
# LOCAL_NETWORK
LOCAL_NETWORK=192.168.0.0/24

# Source: Portainer field
# watch-dir-enabled
TRANSMISSION_WATCH_DIR_ENABLED=true

# Source: Compose variable
CONTAINER_NAME=transmission-openvpn-latest
