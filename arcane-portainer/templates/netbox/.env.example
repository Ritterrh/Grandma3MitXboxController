# Environment values generated from Portainer template: Netbox

# Source: Portainer field
# Run 'id [USER]' for the owner of the host volume directories to get the UID to use here.
PUID=1000

# Source: Portainer field
# Run 'id [USER]' for the owner of the host volume directories to get the GID to use here.
PGID=1000

# Source: Portainer field
# specify a timezone to use, see this [list](https://en.wikipedia.org/wiki/List_of_tz_database_time_zones#List).
TZ=Etc/UTC

# Source: Portainer field
# Email address for `admin` account
SUPERUSER_EMAIL=

# Source: Portainer field
# Password for `admin` account
SUPERUSER_PASSWORD=change-me

# Source: Portainer field
# The hostname you will use to access the app (e.g., netbox.example.com)
ALLOWED_HOST=localhost

# Source: Portainer field
# Database name (default: netbox)
DB_NAME=app

# Source: Portainer field
# Database user
DB_USER=user

# Source: Portainer field
# Database password
DB_PASSWORD=change-me

# Source: Portainer field
# Database host (default: postgres)
DB_HOST=localhost

# Source: Portainer field
# Database port (default: 5432)
DB_PORT=8080

# Source: Portainer field
# Redis host (default: redis)
REDIS_HOST=localhost

# Source: Portainer field
# Redis port number (default: 6379)
REDIS_PORT=8080

# Source: Portainer field
# Redis username (default: none)
REDIS_USERNAME=user

# Source: Portainer field
# Redis password (default: none)
REDIS_PASSWORD=change-me

# Source: Portainer field
# Redis database ID for tasks (default: 0)
REDIS_DB_TASK=

# Source: Portainer field
# Redis database ID for caching (default: 1)
REDIS_DB_CACHE=

# Source: Portainer field
# The path you will use to access the app (i.e., /netbox, default: none) [OPTIONAL]
BASE_PATH=./data

# Source: Portainer field
# List of comma-separated, single quoted, trusted origins. Must include protocol, and port if applicable (default: []) [OPTIONAL]
CSRF_TRUSTED_ORIGINS=

# Source: Portainer field
# Enable remote authentication (default: False) [OPTIONAL]
REMOTE_AUTH_ENABLED=

# Source: Portainer field
# Python path to the custom Django authentication backend to use for external user authentication (default: netbox.authentication.RemoteUserBackend) [OPTIONAL]
REMOTE_AUTH_BACKEND=

# Source: Portainer field
# Name of the HTTP header which informs NetBox of the currently authenticated user. (default: HTTP_REMOTE_USER) [OPTIONAL]
REMOTE_AUTH_HEADER=

# Source: Portainer field
# If true, NetBox will automatically create local accounts for users authenticated via a remote service (default: False) [OPTIONAL]
REMOTE_AUTH_AUTO_CREATE_USER=user

# Source: Portainer field
# The list of groups to assign a new user account when created using remote authentication (default: []) [OPTIONAL]
REMOTE_AUTH_DEFAULT_GROUPS=

# Source: Portainer field
# A mapping of permissions to assign a new user account when created using remote authentication (default: {}) [OPTIONAL]
REMOTE_AUTH_DEFAULT_PERMISSIONS=

# Source: Compose variable
CONTAINER_NAME=netbox
