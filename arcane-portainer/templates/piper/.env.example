# Environment values generated from Portainer template: Piper

# Source: Portainer field
# Run 'id [USER]' for the owner of the host volume directories to get the UID to use here.
PUID=1000

# Source: Portainer field
# Run 'id [USER]' for the owner of the host volume directories to get the GID to use here.
PGID=1000

# Source: Portainer field
# specify a timezone to use, see this [list](https://en.wikipedia.org/wiki/List_of_tz_database_time_zones#List).
TZ=Etc/UTC

# Source: Portainer field
# The [Piper voice](https://huggingface.co/rhasspy/piper-voices/tree/main) to use, in the format `<language>-<name>-<quality>`
PIPER_VOICE=en_US-lessac-medium

# Source: Portainer field
# If set to `true`, or any other value, the container will not attempt to download models from HuggingFace and will only use locally-provided models. [OPTIONAL]
LOCAL_ONLY=

# Source: Portainer field
# Voice speaking rate, 1.0 is default with < 1.0 being faster and > 1.0 being slower. [OPTIONAL]
PIPER_LENGTH=1.0

# Source: Portainer field
# Controls the variability of the voice by adding noise. Values above 1 will start to degrade audio. [OPTIONAL]
PIPER_NOISE=0.667

# Source: Portainer field
# Controls the variability of speaking cadence. Values above 1 produce extreme stutters and pauses. [OPTIONAL]
PIPER_NOISEW=0.333

# Source: Portainer field
# Speaker number to use if the voice supports multiple speakers. [OPTIONAL]
PIPER_SPEAKER=0

# Source: Portainer field
# Setting to `true`, or any other value, will disable support for streaming audio on sentence boundaries. [OPTIONAL]
NO_STREAMING=

# Source: Compose variable
CONTAINER_NAME=piper
