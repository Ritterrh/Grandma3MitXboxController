# Environment values generated from Portainer template: Dokku (container)

# Source: Portainer field
# Global hostname to be registered by Dokku
DOKKU_HOSTNAME=localhost

# Source: Portainer field
# Image build cache path. Generally set to <data dir> + '/home/dokku'
DOKKU_HOST_ROOT=/var/lib/dokku/home/dokku

# Source: Compose variable
CONTAINER_NAME=dokku-container
