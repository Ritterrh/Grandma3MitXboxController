# Environment values generated from Portainer template: Paperless NGX

# Source: Portainer field
# for UserID
PUID=1000

# Source: Portainer field
# for GroupID
PGID=1000

# Source: Portainer field
# Specify a timezone to use for example America/New_York
TZ=America/New_York

# Source: Portainer field
# Example https://paperless.example.com.  It would be best to run this behind a reverse proxy
PAPERLESSURL=

# Source: Portainer field
# Set the name of the default admin user.
ADMIN_USER=user

# Source: Portainer field
# Set the password of the default admin user.
ADMIN_PASS=change-me

# Source: Portainer field
# This should be a very long sequence of random characters.
RANDOMKEY=

# Source: Portainer field
# The default language to use for OCR
LANG=eng

# Source: Compose environment
PAPERLESS_REDIS=redis://broker:6379
