# Environment values generated from Portainer template: tela

# Source: Portainer field
# Public base URL
TELA_PUBLIC_BASE_URL=http://localhost:8780

# Source: Portainer field
# Postgres password (required, no default)
TELA_PG_PASSWORD=change-me

# Source: Portainer field
# Share secret (required) — generate with: openssl rand -hex 32
TELA_SHARE_SECRET=change-me

# Source: Portainer field
# API key / PAT secret (required) — generate with: openssl rand -hex 32
TELA_API_KEY_SECRET=change-me

# Source: Compose environment
TELA_SITE_ADDRESS=:80

# Source: Compose environment
TELA_UPSTREAM_BACKEND=backend:8080

# Source: Compose environment
TELA_UPSTREAM_FRONTEND=frontend:80

# Source: Compose environment
TELA_GOTENBERG_URL=http://gotenberg:3000

# Source: Compose environment
TELA_PDF_RENDER_BASE_URL=http://proxy

# Source: Compose environment
TELA_DECK_URL=http://deck:3344

# Source: Compose environment
POSTGRES_USER=tela

# Source: Compose environment
POSTGRES_DB=tela
