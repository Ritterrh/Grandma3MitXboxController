# Environment values generated from Portainer template: Kimai

# Source: Portainer field
# Run 'id [USER]' for the owner of the host volume directories to get the UID to use here.
PUID=1000

# Source: Portainer field
# Run 'id [USER]' for the owner of the host volume directories to get the GID to use here.
PGID=1000

# Source: Portainer field
# specify a timezone to use, see this [list](https://en.wikipedia.org/wiki/List_of_tz_database_time_zones#List).
TZ=Etc/UTC

# Source: Portainer field
# Configure your database connection, see Application Setup instructions.
DATABASE_URL=mysql://your_db_user:your_db_pass@your_db_host:3306/your_db_name?charset=your_db_charset&serverVersion=your_db_version

# Source: Portainer field
# If behind a reverse proxy set this to its IP or network CIDR so that Kimai trusts its headers. [OPTIONAL]
TRUSTED_PROXIES=127.0.0.1/32

# Source: Compose variable
CONTAINER_NAME=kimai
